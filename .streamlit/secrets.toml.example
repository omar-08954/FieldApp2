# Keep the real secrets in .streamlit/secrets.toml or the deployment secret store.
DATABASE_URL = "postgresql://user:password@host:5432/database"

# Required for report-image uploads. Use a service-role key only in the server
# secret store; never expose it in browser code or commit the real file.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "your-service-role-key"
SUPABASE_STORAGE_BUCKET = "daily-reports"
